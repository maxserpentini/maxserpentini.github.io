    "index.html": {
      "settings": {
        "main": true,
        "title": "Max Serpentini | Singer-Songwriter & Percussive Guitarist",
        "meta_descr": "Max Serpentini is a Canadian-Italian musician, known for his virtuosic percussive-acoustic guitar stylings, soulful vocals, and powerful stage presence.  His music spans across genres, including blues, roots, rock, and world music.",
        "header_custom": "",
        "footer_custom": "",
        "html_before": "",
        "socialSharingUrl": ""
